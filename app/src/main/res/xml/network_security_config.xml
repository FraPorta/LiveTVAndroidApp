<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Scraping source (default and any user-configured hostname) -->
        <domain includeSubdomains="true">livetv.sx</domain>
        <!-- Acestream engine HTTP proxy running locally on device -->
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- Localhost alias used by some Acestream builds -->
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
